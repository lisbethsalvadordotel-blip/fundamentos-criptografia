--------------------------------------------------
OTRO MÉTODO DIFERENTE
--------------------------------------------------

Método utilizando diccionario.

Crear archivo:

nano caesar_diccionario.py

Pegar código:

mensaje = input("Escribe el mensaje: ")

cifrado = {
    'a':'d', 'b':'e', 'c':'f',
    'd':'g', 'e':'h', 'f':'i',
    'g':'j', 'h':'k', 'i':'l',
    'j':'m', 'k':'n', 'l':'o',
    'm':'p', 'n':'q', 'o':'r',
    'p':'s', 'q':'t', 'r':'u',
    's':'v', 't':'w', 'u':'x',
    'v':'y', 'w':'z', 'x':'a',
    'y':'b', 'z':'c'
}

resultado = ""

for letra in mensaje.lower():
    if letra in cifrado:
        resultado += cifrado[letra]
    else:
        resultado += letra

print("Mensaje cifrado:", resultado)

